{
  "name": "splendor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build:client": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.json --noEmit",
    "start:server": "tsx server/index.ts",
    "build": "npm run build:client",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:online:e2e": "node online.e2e.test.mjs",
    "demo:online:video": "node capture-online-video-lite.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@chakra-ui/react": "^2.10.4",
    "@chakra-ui/theme": "^3.4.6",
    "@chakra-ui/theme-tools": "^2.2.6",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@types/canvas-confetti": "^1.9.0",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^10.18.0",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.6",
    "react": "^18.3.1",
    "react-confetti": "^6.2.2",
    "react-dom": "^18.3.1",
    "react-use": "^17.6.0",
    "tsx": "^4.21.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "puppeteer": "^24.37.5",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^3.2.4"
  }
}
